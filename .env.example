# Firebase web config (client-safe)
REACT_APP_ENV_FIREBASE_API_KEY=
REACT_APP_ENV_FIREBASE_AUTH_DOMAIN=
REACT_APP_ENV_FIREBASE_PROJECT_ID=
REACT_APP_ENV_FIREBASE_STORAGE_BUCKET=
REACT_APP_ENV_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_ENV_FIREBASE_APP_ID=
REACT_APP_ENV_FIREBASE_MEASUREMENT_ID=

# YouTube Data API (client-safe, restrict by HTTP referrer)
REACT_APP_YOUTUBE_API_KEY=

# Region for Firebase callable functions
REACT_APP_FUNCTIONS_REGION=us-central1
