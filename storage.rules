rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Transcription audio blobs uploaded by the Cloud Function worker.
    // Clients may read their own; only Admin SDK writes.
    match /audio/{uid}/{file=**} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
